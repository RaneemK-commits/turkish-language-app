    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "kitap + ı → ?",
    "answer": ["kitabı"],
    "distractors": ["kitapı", "kitapi", "kitabi"],
    "explanation": {
      "rule": "Final p softens to b before a vowel-initial suffix.",
      "why": "kitap ends in voiceless p; the vowel ı forces p → b."
    },
    "targets": ["no_consonant_softening", "wrong_suffix_vowel"]
  },
