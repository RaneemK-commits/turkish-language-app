    "prompt": "ağaç + ı → ?",
    "answer": ["ağacı"],
    "distractors": ["ağaçı", "ağaci"],
    "explanation": {
      "rule": "Final ç softens to c before a vowel.",
      "why": "ağaç + vowel → ağac-; back vowel a keeps the suffix as ı."
    },
    "targets": ["no_consonant_softening"]
