[
  {
    "id": "accusative.ex.001",
    "conceptId": "accusative",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "“I read THE book.” Which form does ‘kitap’ take?",
    "answer": ["kitabı"],
    "distractors": ["kitap", "kitaba", "kitapta"],
    "explanation": {
      "rule": "Definite object → accusative -(y)I; final p softens to b.",
      "why": "‘The book’ is specific, so it must be marked: kitabı."
    },
    "targets": ["wrong_case_choice", "no_consonant_softening"]
  },
  {
    "id": "accusative.ex.002",
    "conceptId": "accusative",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "Which sentence means “I read A book” (indefinite)?",
    "answer": ["Kitap okudum."],
    "distractors": ["Kitabı okudum."],
    "explanation": {
      "rule": "An indefinite object takes NO accusative — it stays bare.",
      "why": "Kitap okudum = a book (any book); Kitabı okudum = the book."
    },
    "targets": ["wrong_case_choice"]
  },
  {
    "id": "accusative.ex.003",
    "conceptId": "accusative",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "su + accusative → ?",
    "answer": ["suyu"],
    "distractors": ["suyı", "suu", "susu"],
    "explanation": {
      "rule": "Vowel-final stem takes buffer -y-; u is back rounded → -yu.",
      "why": "su + y + u → suyu."
    },
    "targets": ["missing_buffer_y", "wrong_suffix_vowel"]
  },
  {
