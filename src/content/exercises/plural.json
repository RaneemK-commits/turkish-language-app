    "prompt": "The plural of “okul” (school)?",
    "answer": ["okullar"],
    "distractors": ["okuller", "okullur"],
    "explanation": {
      "rule": "-lAr: back vowel u → -lar.",
      "why": "okul’s last vowel is u (back). A suffixes never take u/ü — only a or e."
