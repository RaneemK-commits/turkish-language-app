    "difficulty": 1,
    "prompt": "The plural of “ev” (house)?",
    "answer": ["evler"],
    "distractors": ["evlar", "evlır", "evlur"],
    "explanation": {
      "rule": "-lAr: front vowel e → -ler.",
      "why": "ev has the front vowel e."
    },
    "targets": ["wrong_suffix_vowel"]
