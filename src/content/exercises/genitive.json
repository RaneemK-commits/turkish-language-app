[
  {
    "id": "genitive.ex.001",
    "conceptId": "genitive",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "“of the house” → ?",
    "answer": ["evin"],
    "distractors": ["evın", "evun", "evnin"],
    "explanation": {
      "rule": "Consonant-final → -(n)In without the buffer; front e → -in.",
      "why": "evin — the house's."
    },
    "targets": ["wrong_suffix_vowel", "missing_buffer_n"]
  },
  {
    "id": "genitive.ex.002",
    "conceptId": "genitive",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "kapı + genitive → ?",
    "answer": ["kapının"],
    "distractors": ["kapıın", "kapınin", "kapıyın"],
    "explanation": {
      "rule": "Vowel-final → buffer -n-; back ı → -nın.",
      "why": "kapının — the genitive's buffer is -n-, not -y-."
    },
    "targets": ["missing_buffer_n", "wrong_suffix_vowel"]
  },
  {
    "id": "genitive.ex.003",
    "conceptId": "genitive",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "“my” (pronoun genitive) → ?",
    "answer": ["benim"],
    "distractors": ["beni", "benin", "bene"],
