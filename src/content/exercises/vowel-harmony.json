    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "The last vowel of “okul” is u. Which vowel does a 4-fold I suffix take?",
    "answer": ["u"],
    "distractors": ["ı", "i", "ü"],
    "explanation": {
      "rule": "4-fold I: back + rounded → u.",
      "why": "‘u’ in ‘okul’ is a back, rounded vowel."
    },
    "targets": ["wrong_suffix_vowel"]
  },
  {
    "id": "vowel-harmony.ex.002",
