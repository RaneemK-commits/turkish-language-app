    "difficulty": 2,
    "prompt": "kapı + ___  (plural)",
    "answer": ["lar"],
    "distractors": ["ler"],
    "explanation": {
      "rule": "2-fold A: back vowel → a, so -lAr → -lar.",
      "why": "The last vowel of ‘kapı’ is ı (back)."
