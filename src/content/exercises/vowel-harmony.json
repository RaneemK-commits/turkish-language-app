    "difficulty": 1,
    "prompt": "Which is correct?",
    "answer": ["günler"],
    "distractors": ["günlar", "günlur", "günlür"],
    "explanation": {
      "rule": "2-fold A: front vowel → e, so -lAr → -ler.",
      "why": "‘ü’ in ‘gün’ is a front vowel."
    },
    "targets": ["wrong_suffix_vowel"]
  },
  {
