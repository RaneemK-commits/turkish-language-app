[
  {
    "id": "possessive.ex.001",
    "conceptId": "possessive",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "“my house” → ?",
    "answer": ["evim"],
    "distractors": ["evin", "evi", "evım"],
    "explanation": {
      "rule": "1sg possessive -(I)m; front e → -im.",
      "why": "evim — the vowel appears because ev ends in a consonant."
    },
    "targets": ["wrong_possessive_person", "wrong_suffix_vowel"]
  },
  {
    "id": "possessive.ex.002",
    "conceptId": "possessive",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "“his/her car” → ?",
    "answer": ["arabası"],
    "distractors": ["arabaı", "arabasi", "arabam"],
    "explanation": {
      "rule": "3sg after a vowel takes buffer -s-: -sI.",
      "why": "arabası — back a → -sı."
    },
    "targets": ["missing_buffer_s", "wrong_suffix_vowel"]
  },
  {
