  {
    "id": "cases-dla.ex.011",
    "conceptId": "cases-dla",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 4,
    "prompt": "Which sentence means “The bird came from the tree”?",
    "answer": ["Kuş ağaçtan geldi."],
    "distractors": ["Kuş ağaca geldi.", "Kuş ağaçta geldi."],
    "explanation": {
      "rule": "‘From’ → ablative -DAn; voiceless ç → -tan.",
      "why": "ağaca = to the tree; ağaçta = in the tree; ağaçtan = from it."
    },
    "targets": ["wrong_case_choice", "wrong_consonant_harmony"]
  },
  {
    "id": "cases-dla.ex.012",
    "conceptId": "cases-dla",
    "type": "exercise",
    "format": "fill_blank",
    "difficulty": 4,
    "prompt": "Translate: I went to İstanbul.",
    "answer": ["İstanbul'a gittim."],
    "alternates": ["İstanbula gittim."],
    "explanation": {
      "rule": "Proper noun + dative → İstanbul'a (apostrophe); verb last.",
      "why": "Motion toward a place takes the dative."
    },
    "targets": ["wrong_case_choice", "missing_apostrophe"]
  },
  {
    "id": "cases-dla.ex.013",
