  {
    "id": "cases-dla.ex.001",
    "conceptId": "cases-dla",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "“to school” → ?",
    "answer": ["okula"],
    "distractors": ["okulda", "okuldan", "okulu"],
    "explanation": {
      "rule": "Motion toward → dative -(y)A.",
      "why": "okul + a — back vowel u → -a."
    },
    "targets": ["wrong_case_choice"]
  },
  {
    "id": "cases-dla.ex.002",
    "conceptId": "cases-dla",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "“at home / in the house” → ?",
    "answer": ["evde"],
    "distractors": ["eve", "evden", "evi"],
    "explanation": {
      "rule": "Location → locative -DA; voiced v → -de.",
      "why": "evde — being at, not moving to."
    },
    "targets": ["wrong_case_choice", "wrong_consonant_harmony"]
  },
  {
    "id": "cases-dla.ex.003",
    "conceptId": "cases-dla",
    "type": "exercise",
    "format": "multiple_choice",
    "difficulty": 1,
    "prompt": "“from the mountain” → ?",
    "answer": ["dağdan"],
    "distractors": ["dağda", "dağa", "dağdın"],
    "explanation": {
      "rule": "Motion away → ablative -DAn.",
      "why": "dağ + dan — ğ is voiced → d; a is back → -dan."
    },
    "targets": ["wrong_case_choice"]
  },
  {
    "id": "cases-dla.ex.004",
    "conceptId": "cases-dla",
    "type": "exercise",
    "format": "suffix_match",
    "difficulty": 2,
    "prompt": "kapı + ___ (dative: to)",
    "answer": ["ya"],
    "distractors": ["a", "ye", "da"],
    "explanation": {
      "rule": "Vowel-final stem → buffer -y-; back ı → -ya.",
      "why": "kapıya — to the door."
    },
    "targets": ["missing_buffer_y", "wrong_suffix_vowel"]
  },
  {
    "id": "cases-dla.ex.005",
    "conceptId": "cases-dla",
    "type": "exercise",
    "format": "suffix_match",
    "difficulty": 2,
    "prompt": "kitap + ___ (locative: at/in)",
    "answer": ["ta"],
    "distractors": ["da", "te", "tı"],
    "explanation": {
      "rule": "Voiceless p → D surfaces as t; back a → -ta.",
      "why": "kitapta — in the book."
    },
    "targets": ["wrong_consonant_harmony", "wrong_suffix_vowel"]
  },
